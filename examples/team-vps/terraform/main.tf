# AWS provisioning for the agicash team VPS.
# Region, instance, security group, key pair declared here as we fill in.

terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}
